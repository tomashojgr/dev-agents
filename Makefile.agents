# dev-agents commands
# Included automatically by Installer into project Makefile

AGENTS_BIN  := vendor/bin
DA_AI_PRINT ?= claude --print
DA_AI_RUN   ?= claude
DA_AI_AUTO  ?= claude --dangerously-skip-permissions

# ── Task management ───────────────────────────────────────────────────────────

.PHONY: da-spec
da-spec: ## Create task specification. Usage: make da-spec TASK="add DKIM validation"
	@test -n "$(TASK)" || (echo '❌ TASK is required. Usage: make da-spec TASK="add DKIM validation"' && exit 1)
	$(AGENTS_BIN)/da-spec "$(TASK)"

.PHONY: da-spec-approve
da-spec-approve: ## Approve task specification. Usage: make da-spec-approve TASK=1
	@test -n "$(TASK)" || (echo '❌ TASK is required. Usage: make da-spec-approve TASK=1' && exit 1)
	$(AGENTS_BIN)/da-spec-approve "$(TASK)"

.PHONY: da-spec-continue
da-spec-continue: ## Continue refining a task spec. Usage: make da-spec-continue TASK=1
	@test -n "$(TASK)" || (echo '❌ TASK is required. Usage: make da-spec-continue TASK=1' && exit 1)
	$(AGENTS_BIN)/da-spec-continue "$(TASK)"

.PHONY: da-code
da-code: ## Implement an approved task autonomously. Usage: make da-code TASK=1
	@test -n "$(TASK)" || (echo '❌ TASK is required. Usage: make da-code TASK=1' && exit 1)
	$(AGENTS_BIN)/da-code "$(TASK)"

.PHONY: da-commit
da-commit: ## Generate a commit message from staged diff. Usage: make da-commit TASK=1
	@test -n "$(TASK)" || (echo '❌ TASK is required. Usage: make da-commit TASK=1' && exit 1)
	$(AGENTS_BIN)/da-commit "$(TASK)"

.PHONY: da-lint
da-lint: ## Run lint agent.
	$(AGENTS_BIN)/da-lint

.PHONY: da-lint-fix
da-lint-fix: ## Run linters and launch AI agent to fix issues interactively.
	$(AGENTS_BIN)/da-lint --save-prompt .dev-agents-lint || $(DA_AI_RUN) "$$(cat .dev-agents-lint)"

.PHONY: da-review
da-review: ## Address PR review comments autonomously. Usage: make da-review TASK=1
	@test -n "$(TASK)" || (echo '❌ TASK is required. Usage: make da-review TASK=1' && exit 1)
	$(AGENTS_BIN)/da-review "$(TASK)"

.PHONY: da-release
da-release: ## Run release agent.
	$(AGENTS_BIN)/da-release

# ── Help ──────────────────────────────────────────────────────────────────────

.PHONY: da-help
da-help: ## Show dev-agents commands
	@echo ""
	@echo "dev-agents commands:"
	@grep -hE '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-12s\033[0m %s\n", $$1, $$2}'
	@echo ""
