#!/usr/bin/env bash
set -euo pipefail

TASK_ID="${1:-}"
if [ -z "$TASK_ID" ]; then
    echo "Usage: da-spec-approve <task-id>"
    echo "Example: da-spec-approve task-001-dkim-validation"
    exit 1
fi

TASK_FILE=".tasks/${TASK_ID}/TASK.md"
if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

STATUS=$(grep -m1 '^status:' "$TASK_FILE" | sed 's/^status:[[:space:]]*//' || echo "draft")

if [ "$STATUS" = "approved" ]; then
    echo "✅ Task already approved: ${TASK_ID}"
    exit 0
fi

if [ "$STATUS" = "done" ]; then
    echo "✅ Task already done: ${TASK_ID}"
    exit 0
fi

echo "┌─────────────────────────────────────────────────────────────┐"
echo "│ Task: ${TASK_ID}"
echo "├─────────────────────────────────────────────────────────────┤"
echo ""
cat "$TASK_FILE"
echo ""
echo "└─────────────────────────────────────────────────────────────┘"
echo ""

printf 'Approve this task? [Y/n] '
read -r ANSWER
ANSWER=$(printf '%s' "$ANSWER" | tr '[:upper:]' '[:lower:]')

if [ "$ANSWER" = "n" ]; then
    echo "❌ Approval cancelled"
    exit 1
fi

TMP=$(mktemp)
sed 's/^status:[[:space:]]*.*/status: approved/' "$TASK_FILE" > "$TMP"
mv "$TMP" "$TASK_FILE"

echo "✅ Task approved: ${TASK_ID}"
echo ""
echo "Next step:"
echo "  make da-code TASK=${TASK_ID}"
