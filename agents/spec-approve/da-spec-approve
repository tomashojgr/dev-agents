#!/usr/bin/env bash
set -euo pipefail

# ── Resolve task reference to full task ID ────────────────────────────────────

resolve_task() {
    local arg="$1" tasks_dir=".tasks" match matches count padded
    [ -d "${tasks_dir}/${arg}" ] && { echo "$arg"; return 0; }
    if [[ "$arg" =~ ^[0-9]+$ ]]; then
        padded=$(printf '%03d' "$arg")
        match=$(find "$tasks_dir" -maxdepth 1 -type d -name "task-${padded}-*" 2>/dev/null | head -1)
        [ -n "$match" ] && { basename "$match"; return 0; }
    fi
    matches=$(find "$tasks_dir" -maxdepth 1 -type d -name "*${arg}*" 2>/dev/null | sort)
    count=$(echo "$matches" | grep -c . 2>/dev/null || true)
    if [ "$count" -eq 1 ]; then basename "$matches"; return 0
    elif [ "$count" -gt 1 ]; then
        echo "❌ Multiple tasks match '${arg}':" >&2
        echo "$matches" | while IFS= read -r m; do echo "  $(basename "$m")"; done >&2
        return 1
    fi
    echo "❌ No task found matching '${arg}'" >&2; return 1
}

# ── Main ──────────────────────────────────────────────────────────────────────

TASK_ARG="${1:-}"
if [ -z "$TASK_ARG" ]; then
    echo "Usage: da-spec-approve <task>"
    echo "Example: da-spec-approve 1"
    echo "         da-spec-approve dkim"
    echo "         da-spec-approve task-001-add-dkim-validation"
    exit 1
fi

TASK_ID=$(resolve_task "$TASK_ARG") || exit 1

TASK_DIR=".tasks/${TASK_ID}"
TASK_FILE="${TASK_DIR}/TASK.md"
TASK_JSON="${TASK_DIR}/task.json"

if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

STATUS=$(grep '"status"' "$TASK_JSON" | sed 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')

if [ "$STATUS" = "waiting-for-coding" ]; then
    echo "✅ Task already approved: ${TASK_ID}"
    exit 0
fi

if [ "$STATUS" = "coding-in-progress" ] || [ "$STATUS" = "waiting-for-pr-review" ] || \
   [ "$STATUS" = "review-in-progress" ] || [ "$STATUS" = "task-completed" ]; then
    echo "ℹ️  Task is already past approval (status: ${STATUS})"
    exit 0
fi

echo "┌─────────────────────────────────────────────────────────────┐"
echo "│ Task: ${TASK_ID}"
echo "├─────────────────────────────────────────────────────────────┤"
echo ""
cat "$TASK_FILE"
echo ""
echo "└─────────────────────────────────────────────────────────────┘"
echo ""

printf 'Approve this task for implementation? [Y/n] '
read -r ANSWER
ANSWER=$(printf '%s' "$ANSWER" | tr '[:upper:]' '[:lower:]')

if [ "$ANSWER" = "n" ]; then
    echo "❌ Approval cancelled"
    exit 1
fi

# Update status in task.json
TMP=$(mktemp)
sed 's/"status"[[:space:]]*:[[:space:]]*"[^"]*"/"status": "waiting-for-coding"/' "$TASK_JSON" > "$TMP"
mv "$TMP" "$TASK_JSON"

echo "✅ Task approved: ${TASK_ID}"
echo ""
echo "Next step:"
echo "  make da-code TASK=${TASK_ID}"
