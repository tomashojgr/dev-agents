#!/usr/bin/env bash
set -euo pipefail

TASK_ID="${1:-}"
if [ -z "$TASK_ID" ]; then
    echo "Usage: da-code <task-id>"
    echo "Example: da-code task-001-dkim-validation"
    exit 1
fi

TASK_FILE=".tasks/${TASK_ID}/TASK.md"
if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

STATUS=$(grep -m1 '^status:' "$TASK_FILE" | sed 's/^status:[[:space:]]*//' || echo "draft")

if [ "$STATUS" != "approved" ]; then
    echo "❌ Task is not approved (status: ${STATUS})"
    echo "   Run: make da-approve TASK=${TASK_ID}"
    exit 1
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not a git repository"
    exit 1
fi

DIRTY=$(git status --porcelain)
if [ -n "$DIRTY" ]; then
    echo "⚠️  Working tree has uncommitted changes:"
    git status --short
    printf 'Proceed anyway? [y/N] '
    read -r ANSWER
    ANSWER=$(printf '%s' "$ANSWER" | tr '[:upper:]' '[:lower:]')
    if [ "$ANSWER" != "y" ]; then
        echo "❌ Aborted. Commit or stash changes first."
        exit 1
    fi
fi

TASK_CONTENTS=$(cat "$TASK_FILE")
GOAL=$(awk '/^## Goal/{found=1; next} found && /^## /{exit} found && NF{print; exit}' "$TASK_FILE")

CLAUDE_MD_CONTEXT=""
if [ -f "CLAUDE.md" ]; then
    CLAUDE_MD_CONTEXT=$(cat "CLAUDE.md")
fi

PROMPT="You are an expert PHP developer implementing a well-defined task.

${CLAUDE_MD_CONTEXT}

Implement the following task exactly as specified. Follow the acceptance criteria. Stay within the defined scope. Do not make changes outside the scope.

When done:
1. Run any tests if a test suite exists
2. Stage only files within the task scope with git add
3. Report what was implemented

TASK SPECIFICATION:
${TASK_CONTENTS}"

echo "🚀 Starting AI coding agent for task: ${TASK_ID}"
echo "   Goal: ${GOAL}"
echo ""

read -ra AI_RUN <<< "${DA_AI_RUN:-claude}"
"${AI_RUN[@]}" "$PROMPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ AI agent exited with code $EXIT_CODE"
    exit $EXIT_CODE
fi

TMP=$(mktemp)
sed 's/^status:[[:space:]]*.*/status: done/' "$TASK_FILE" > "$TMP"
mv "$TMP" "$TASK_FILE"

echo ""
echo "✅ Task marked as done: ${TASK_ID}"
echo ""
echo "Next steps:"
echo "  git add <files>"
echo "  make da-commit TASK=${TASK_ID}"
