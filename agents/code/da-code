#!/usr/bin/env bash
set -euo pipefail

# ── Resolve task reference to full task ID ────────────────────────────────────

resolve_task() {
    local arg="$1" tasks_dir=".tasks" match matches count padded
    [ -d "${tasks_dir}/${arg}" ] && { echo "$arg"; return 0; }
    if [[ "$arg" =~ ^[0-9]+$ ]]; then
        padded=$(printf '%03d' "$arg")
        match=$(find "$tasks_dir" -maxdepth 1 -type d -name "task-${padded}-*" 2>/dev/null | head -1)
        [ -n "$match" ] && { basename "$match"; return 0; }
    fi
    matches=$(find "$tasks_dir" -maxdepth 1 -type d -name "*${arg}*" 2>/dev/null | sort)
    count=$(echo "$matches" | grep -c . 2>/dev/null || true)
    if [ "$count" -eq 1 ]; then basename "$matches"; return 0
    elif [ "$count" -gt 1 ]; then
        echo "❌ Multiple tasks match '${arg}':" >&2
        echo "$matches" | while IFS= read -r m; do echo "  $(basename "$m")"; done >&2
        return 1
    fi
    echo "❌ No task found matching '${arg}'" >&2; return 1
}

# ── Main ──────────────────────────────────────────────────────────────────────

TASK_ARG="${1:-}"
if [ -z "$TASK_ARG" ]; then
    echo "Usage: da-code <task>"
    echo "Example: da-code 1"
    echo "         da-code dkim"
    echo "         da-code task-001-add-dkim-validation"
    exit 1
fi

TASK_ID=$(resolve_task "$TASK_ARG") || exit 1

TASK_DIR=".tasks/${TASK_ID}"
TASK_FILE="${TASK_DIR}/TASK.md"
TASK_JSON="${TASK_DIR}/task.json"

if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

STATUS=$(grep '"status"' "$TASK_JSON" | sed 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
if [ "$STATUS" != "waiting-for-coding" ]; then
    echo "❌ Task is not ready for coding (status: ${STATUS})"
    echo "   Run: make da-spec-approve TASK=${TASK_ID}"
    exit 1
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not a git repository"
    exit 1
fi

DIRTY=$(git status --porcelain)
if [ -n "$DIRTY" ]; then
    echo "❌ Working tree has uncommitted changes. Commit or stash them first."
    git status --short
    exit 1
fi

# ── Create task branch ─────────────────────────────────────────────────────────

BRANCH="$TASK_ID"

if git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
    echo "ℹ️  Branch '${BRANCH}' already exists, switching to it."
    git checkout "$BRANCH"
else
    git checkout -b "$BRANCH"
    echo "ℹ️  Created branch '${BRANCH}'"
fi

# ── Mark as coding-in-progress ────────────────────────────────────────────────

TMP=$(mktemp)
sed 's/"status"[[:space:]]*:[[:space:]]*"[^"]*"/"status": "coding-in-progress"/' "$TASK_JSON" > "$TMP"
mv "$TMP" "$TASK_JSON"

# ── Build prompt ───────────────────────────────────────────────────────────────

TASK_CONTENTS=$(cat "$TASK_FILE")
GOAL=$(awk '/^## Goal/{found=1; next} found && /^## /{exit} found && NF{print; exit}' "$TASK_FILE")

CLAUDE_MD_CONTEXT=""
if [ -f "CLAUDE.md" ]; then
    CLAUDE_MD_CONTEXT=$(cat "CLAUDE.md")
fi

PROMPT="You are an expert developer implementing a well-defined task on a feature branch.

${CLAUDE_MD_CONTEXT}

Work fully autonomously — do not ask for confirmation or clarification, make your best judgment based on the specification.

When done:
1. Run tests if a test suite exists and fix any failures
2. Stage all changed files with git add
3. Commit using conventional commit messages (feat:, fix:, etc.)
4. Do NOT push or create a PR — the calling script handles that

TASK SPECIFICATION:
${TASK_CONTENTS}"

# ── Launch AI agent ────────────────────────────────────────────────────────────

echo "🚀 Starting autonomous implementation of: ${TASK_ID}"
echo "   Goal: ${GOAL}"
echo "   Branch: ${BRANCH}"
echo ""

read -ra AI_AUTO <<< "${DA_AI_AUTO:-claude --dangerously-skip-permissions}"
"${AI_AUTO[@]}" "$PROMPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ AI agent exited with code $EXIT_CODE"
    exit $EXIT_CODE
fi

# ── Lint before PR ─────────────────────────────────────────────────────────────

LINT_BIN="vendor/bin/da-lint"
if [ -f "$LINT_BIN" ]; then
    echo ""
    echo "▶ Running lint..."
    LINT_FAILED=0
    "$LINT_BIN" --save-prompt .dev-agents-lint || LINT_FAILED=$?

    if [ $LINT_FAILED -ne 0 ] && [ -s ".dev-agents-lint" ]; then
        echo "▶ AI fixing lint issues..."
        read -ra AI_AUTO_CMD <<< "${DA_AI_AUTO:-claude --dangerously-skip-permissions}"
        "${AI_AUTO_CMD[@]}" "$(cat .dev-agents-lint)"
        rm -f .dev-agents-lint
        echo "▶ Re-checking lint..."
        "$LINT_BIN" || echo "⚠️  Some lint issues remain — review the PR."
    fi
fi

# ── Push branch and create PR ──────────────────────────────────────────────────

echo ""
echo "▶ Pushing branch..."
git push -u origin "$BRANCH"

echo "▶ Creating pull request..."

PR_BODY=$(cat "$TASK_FILE")

gh pr create \
    --title "$GOAL" \
    --body "$PR_BODY" \
    --head "$BRANCH"

# ── Update status to waiting-for-pr-review ────────────────────────────────────

TMP=$(mktemp)
sed 's/"status"[[:space:]]*:[[:space:]]*"[^"]*"/"status": "waiting-for-pr-review"/' "$TASK_JSON" > "$TMP"
mv "$TMP" "$TASK_JSON"

git add "$TASK_JSON"
git commit -m "chore: mark ${TASK_ID} as waiting-for-pr-review" 2>/dev/null || true
git push 2>/dev/null || true

echo ""
echo "✅ Done. PR created for branch '${BRANCH}'."
echo "   Review, comment, and when ready: make da-review TASK=${TASK_ID}"
