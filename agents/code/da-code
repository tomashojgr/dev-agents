#!/usr/bin/env bash
set -euo pipefail

TASK_ID="${1:-}"
if [ -z "$TASK_ID" ]; then
    echo "Usage: da-code <task-id>"
    echo "Example: da-code task-001-dkim-validation"
    exit 1
fi

TASK_FILE=".tasks/${TASK_ID}/TASK.md"
if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

STATUS=$(grep -m1 '^status:' "$TASK_FILE" | sed 's/^status:[[:space:]]*//' || echo "draft")
if [ "$STATUS" != "approved" ]; then
    echo "❌ Task is not approved (status: ${STATUS})"
    echo "   Run: make da-spec-approve TASK=${TASK_ID}"
    exit 1
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not a git repository"
    exit 1
fi

DIRTY=$(git status --porcelain)
if [ -n "$DIRTY" ]; then
    echo "❌ Working tree has uncommitted changes. Commit or stash them first."
    git status --short
    exit 1
fi

# ── Create task branch ─────────────────────────────────────────────────────────

BRANCH="$TASK_ID"

if git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
    echo "ℹ️  Branch '${BRANCH}' already exists, switching to it."
    git checkout "$BRANCH"
else
    git checkout -b "$BRANCH"
    echo "ℹ️  Created branch '${BRANCH}'"
fi

# ── Build prompt ───────────────────────────────────────────────────────────────

TASK_CONTENTS=$(cat "$TASK_FILE")
GOAL=$(awk '/^## Goal/{found=1; next} found && /^## /{exit} found && NF{print; exit}' "$TASK_FILE")

CLAUDE_MD_CONTEXT=""
if [ -f "CLAUDE.md" ]; then
    CLAUDE_MD_CONTEXT=$(cat "CLAUDE.md")
fi

PROMPT="You are an expert developer implementing a well-defined task on a feature branch.

${CLAUDE_MD_CONTEXT}

Work fully autonomously — do not ask for confirmation or clarification, make your best judgment based on the specification.

When done:
1. Run tests if a test suite exists and fix any failures
2. Stage all changed files with git add
3. Commit using conventional commit messages (feat:, fix:, etc.)
4. Do NOT push or create a PR — the calling script handles that

TASK SPECIFICATION:
${TASK_CONTENTS}"

# ── Launch AI agent ────────────────────────────────────────────────────────────

echo "🚀 Starting autonomous implementation of: ${TASK_ID}"
echo "   Goal: ${GOAL}"
echo "   Branch: ${BRANCH}"
echo ""

read -ra AI_AUTO <<< "${DA_AI_AUTO:-claude --dangerously-skip-permissions}"
"${AI_AUTO[@]}" "$PROMPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ AI agent exited with code $EXIT_CODE"
    exit $EXIT_CODE
fi

# ── Lint before PR ────────────────────────────────────────────────────────────

LINT_BIN="vendor/bin/da-lint"
if [ -f "$LINT_BIN" ]; then
    echo ""
    echo "▶ Running lint..."
    LINT_FAILED=0
    "$LINT_BIN" --save-prompt .dev-agents-lint || LINT_FAILED=$?

    if [ $LINT_FAILED -ne 0 ] && [ -s ".dev-agents-lint" ]; then
        echo "▶ AI fixing lint issues..."
        read -ra AI_AUTO_CMD <<< "${DA_AI_AUTO:-claude --dangerously-skip-permissions}"
        "${AI_AUTO_CMD[@]}" "$(cat .dev-agents-lint)"
        rm -f .dev-agents-lint
        echo "▶ Re-checking lint..."
        "$LINT_BIN" || echo "⚠️  Some lint issues remain — review the PR."
    fi
fi

# ── Push branch and create PR ──────────────────────────────────────────────────

echo ""
echo "▶ Pushing branch..."
git push -u origin "$BRANCH"

echo "▶ Creating pull request..."

# Build PR body from TASK.md (strip YAML frontmatter)
PR_BODY=$(awk 'BEGIN{f=0} /^---/{f++; next} f>=2{print}' "$TASK_FILE")

gh pr create \
    --title "$GOAL" \
    --body "$PR_BODY" \
    --head "$BRANCH"

# ── Mark task as done ──────────────────────────────────────────────────────────

TMP=$(mktemp)
sed 's/^status:[[:space:]]*.*/status: done/' "$TASK_FILE" > "$TMP"
mv "$TMP" "$TASK_FILE"

git add "$TASK_FILE"
git commit -m "chore: mark ${TASK_ID} as done" 2>/dev/null || true
git push 2>/dev/null || true

echo ""
echo "✅ Done. PR created for branch '${BRANCH}'."
echo "   Review, comment, and when ready: make da-review TASK=${TASK_ID}"
