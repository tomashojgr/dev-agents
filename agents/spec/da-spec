#!/usr/bin/env bash
set -euo pipefail

GOAL="${1:-}"
if [ -z "$GOAL" ]; then
    echo "Usage: da-spec <task description>"
    echo 'Example: da-spec "add DKIM validation to email sender"'
    exit 1
fi

TASKS_DIR=".tasks"
DA_PKG="vendor/tomashojgr/dev-agents"

mkdir -p "$TASKS_DIR"

# Find next task number
NEXT_NUM=$(find "$TASKS_DIR" -maxdepth 2 -name 'TASK.md' 2>/dev/null | wc -l | tr -d ' ')
NEXT_NUM=$((NEXT_NUM + 1))
PADDED=$(printf '%03d' "$NEXT_NUM")

# Slugify goal
SLUG=$(printf '%s' "$GOAL" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-\+/-/g; s/^-\+//; s/-\+$//' | cut -c1-50)

TASK_ID="task-${PADDED}-${SLUG}"
TASK_DIR="${TASKS_DIR}/${TASK_ID}"
TASK_FILE="${TASK_DIR}/TASK.md"
TASK_JSON="${TASK_DIR}/task.json"

mkdir -p "$TASK_DIR"

DATE=$(date +%Y-%m-%d)
TEMPLATE=$(cat "$DA_PKG/templates/TASK.md")

# ── Create task.json with initial status ──────────────────────────────────────

cat > "$TASK_JSON" <<EOF
{
    "id": "${TASK_ID}",
    "status": "spec-in-progress",
    "created": "${DATE}"
}
EOF

# ── Detect project context ─────────────────────────────────────────────────────

PROJECT_CONTEXT=""
if [ -f "composer.json" ]; then
    NAME=$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' composer.json | head -1)
    DESC=$(sed -n 's/.*"description"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' composer.json | head -1)
    PROJECT_CONTEXT="Project: ${NAME}
Description: ${DESC}
"
fi

if [ -f "CLAUDE.md" ]; then
    PROJECT_CONTEXT="${PROJECT_CONTEXT}
Project instructions from CLAUDE.md:
$(cat CLAUDE.md)
"
fi

# ── Build prompt ───────────────────────────────────────────────────────────────

PROMPT="You are a software architect helping a developer turn an idea into a precise task specification.

${PROJECT_CONTEXT}
Task goal: ${GOAL}
Task ID:   ${TASK_ID}
Date:      ${DATE}

Have a natural conversation with the developer to fully understand the requirements. You can raise multiple concerns at once, ask about scope, edge cases, constraints, expected behaviour, or suggest approaches. Drive the discussion until the requirements are clear.

When the developer says something like 'ok, zapiš to', 'ok, write it', 'done', or 'generate':
1. Write the completed specification to ${TASK_FILE} using this template (no frontmatter — pure markdown):

${TEMPLATE}

   Fill in all {{...}} placeholders based on everything discussed. Be concrete about scope (specific files/dirs), acceptance criteria (testable conditions), and implementation notes.

2. Update the \"status\" field in ${TASK_JSON} to \"waiting-for-spec-approval\".

3. Display the full contents of ${TASK_FILE} in the conversation so the developer can review it.

4. Ask: 'Does this look right? Would you like to change anything, or shall I start implementation?'

If the developer wants changes — update the discussion, rewrite ${TASK_FILE}, update ${TASK_JSON} status back to \"waiting-for-spec-approval\", display the spec again, and ask again.

When the developer confirms they are happy and want implementation:
- Update the \"status\" field in ${TASK_JSON} to \"waiting-for-coding\"
- Let the developer know that implementation will start shortly after the session ends

If the developer does not want to implement now — end the session normally (leave status as \"waiting-for-spec-approval\").

Do not write ${TASK_FILE} until the developer first asks you to."

# ── Launch interactive AI session ─────────────────────────────────────────────

read -ra AI_RUN <<< "${DA_AI_RUN:-claude}"
"${AI_RUN[@]}" "$PROMPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ AI agent exited with code $EXIT_CODE"
    rm -rf "$TASK_DIR" 2>/dev/null || true
    exit $EXIT_CODE
fi

if [ ! -f "$TASK_FILE" ]; then
    echo ""
    echo "❌ TASK.md was not created. Tell the agent 'ok, zapiš to' to generate the spec."
    rm -rf "$TASK_DIR" 2>/dev/null || true
    exit 1
fi

# ── Check status and optionally start implementation ──────────────────────────

STATUS=$(grep '"status"' "$TASK_JSON" | sed 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')

if [ "$STATUS" = "waiting-for-coding" ]; then
    echo ""
    echo "▶ Starting implementation of ${TASK_ID}..."

    DA_CODE_BIN="$(dirname "$0")/../code/da-code"
    if [ ! -f "$DA_CODE_BIN" ]; then
        DA_CODE_BIN="vendor/bin/da-code"
    fi
    exec "$DA_CODE_BIN" "$TASK_ID"
else
    echo ""
    echo "✅ Spec saved: .tasks/${TASK_ID}/TASK.md"
    echo "ℹ️  When ready to implement:"
    echo "   make da-spec-approve TASK=${TASK_ID}"
fi
