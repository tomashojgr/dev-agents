#!/usr/bin/env bash
set -euo pipefail

GOAL="${1:-}"
if [ -z "$GOAL" ]; then
    echo "Usage: da-spec <task description>"
    echo 'Example: da-spec "add DKIM validation to email sender"'
    exit 1
fi

TASKS_DIR=".tasks"
DA_PKG="vendor/tomashojgr/dev-agents"

mkdir -p "$TASKS_DIR"

# Find next task number
NEXT_NUM=$(find "$TASKS_DIR" -maxdepth 2 -name 'TASK.md' 2>/dev/null | wc -l | tr -d ' ')
NEXT_NUM=$((NEXT_NUM + 1))
PADDED=$(printf '%03d' "$NEXT_NUM")

# Slugify goal
SLUG=$(printf '%s' "$GOAL" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/-\+/-/g; s/^-\+//; s/-\+$//' | cut -c1-50)

TASK_ID="task-${PADDED}-${SLUG}"
TASK_DIR="${TASKS_DIR}/${TASK_ID}"
TASK_FILE="${TASK_DIR}/TASK.md"
TASK_JSON="${TASK_DIR}/task.json"

mkdir -p "$TASK_DIR"

DATE=$(date +%Y-%m-%d)
TEMPLATE=$(cat "$DA_PKG/templates/TASK.md")

# ── Create task.json with initial status ──────────────────────────────────────

cat > "$TASK_JSON" <<EOF
{
    "id": "${TASK_ID}",
    "status": "spec-in-progress",
    "created": "${DATE}"
}
EOF

# ── Detect project context ─────────────────────────────────────────────────────

PROJECT_CONTEXT=""
if [ -f "composer.json" ]; then
    NAME=$(sed -n 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' composer.json | head -1)
    DESC=$(sed -n 's/.*"description"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' composer.json | head -1)
    PROJECT_CONTEXT="Project: ${NAME}
Description: ${DESC}
"
fi

if [ -f "CLAUDE.md" ]; then
    PROJECT_CONTEXT="${PROJECT_CONTEXT}
Project instructions from CLAUDE.md:
$(cat CLAUDE.md)
"
fi

# ── Build prompt ───────────────────────────────────────────────────────────────

PROMPT="You are a software architect and senior developer helping a developer go from idea to implemented feature.

${PROJECT_CONTEXT}
Task goal: ${GOAL}
Task ID:   ${TASK_ID}
Date:      ${DATE}

── PHASE 1: SPECIFICATION ───────────────────────────────────────────────────────

Have a natural conversation with the developer to fully understand the requirements. Raise concerns, ask about scope, edge cases, constraints, expected behaviour, and suggest approaches. Drive the discussion until the requirements are clear.

When the developer says something like 'ok, zapiš to', 'ok, write it', 'done', or 'generate':
1. Write the completed specification to ${TASK_FILE} (pure markdown, no frontmatter):

${TEMPLATE}

   Fill in all {{...}} placeholders. Be concrete about scope (specific files/dirs), acceptance criteria (testable conditions), and implementation notes.

2. Update the \"status\" field in ${TASK_JSON} to \"waiting-for-spec-approval\".

3. Display the full contents of ${TASK_FILE} in the conversation.

4. Ask: 'Does this look right? Would you like to change anything, or shall I start implementation?'

If the developer wants changes — update ${TASK_FILE}, keep status as \"waiting-for-spec-approval\", display again, and ask again.

Do not write ${TASK_FILE} until the developer first asks you to.

── PHASE 2: IMPLEMENTATION (only when developer confirms) ───────────────────────

When the developer confirms they want implementation, proceed immediately without leaving the session:

1. Update \"status\" in ${TASK_JSON} to \"waiting-for-coding\".

2. Verify the working tree is clean:
   - Run: git status --porcelain
   - If there are uncommitted changes, tell the developer and stop.

3. Create and switch to the task branch:
   - If branch '${TASK_ID}' exists: git checkout ${TASK_ID}
   - Otherwise: git checkout -b ${TASK_ID}

4. Update \"status\" in ${TASK_JSON} to \"coding-in-progress\".

5. Implement the task based on the full context of this conversation and the spec in ${TASK_FILE}. Work autonomously — make your best judgment without asking for confirmation.

6. Before committing — validate against the spec:
   - Re-read the Acceptance Criteria section of ${TASK_FILE}
   - Verify every criterion is met by the implementation
   - Fix any gaps before proceeding

7. Run tests if a test suite exists. Fix any failures before continuing.

8. Run lint if available:
   - If vendor/bin/da-lint exists: run it with --save-prompt .dev-agents-lint
   - If lint fails, fix all reported issues and re-run to confirm clean

9. Stage all changed files and commit with a conventional commit message (feat:, fix:, etc.).

10. Push the branch:
    git push -u origin ${TASK_ID}

11. Create a pull request:
    gh pr create --title \"${GOAL}\" --body \"\$(cat ${TASK_FILE})\" --head ${TASK_ID}

12. Update \"status\" in ${TASK_JSON} to \"waiting-for-pr-review\". Commit and push this change.

13. Tell the developer the PR is open and ready for review.

If the developer does not want to implement now — update \"status\" to \"waiting-for-spec-approval\" and end the session normally."

# ── Launch AI session ──────────────────────────────────────────────────────────

read -ra AI_AUTO <<< "${DA_AI_AUTO:-claude --dangerously-skip-permissions}"
"${AI_AUTO[@]}" "$PROMPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ AI agent exited with code $EXIT_CODE"
    rm -rf "$TASK_DIR" 2>/dev/null || true
    exit $EXIT_CODE
fi

if [ ! -f "$TASK_FILE" ]; then
    echo ""
    echo "❌ TASK.md was not created. Tell the agent 'ok, zapiš to' to generate the spec."
    rm -rf "$TASK_DIR" 2>/dev/null || true
    exit 1
fi

# ── Post-session status check ──────────────────────────────────────────────────

STATUS=$(grep '"status"' "$TASK_JSON" | sed 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')

case "$STATUS" in
    waiting-for-pr-review)
        echo ""
        echo "✅ Implementation complete. PR is open and ready for review."
        echo "   make da-review TASK=${TASK_ID}"
        ;;
    waiting-for-coding|coding-in-progress)
        # Session ended before implementation completed — run da-code as fallback
        echo ""
        echo "▶ Resuming implementation of ${TASK_ID}..."
        DA_CODE_BIN="$(dirname "$0")/../code/da-code"
        [ ! -f "$DA_CODE_BIN" ] && DA_CODE_BIN="vendor/bin/da-code"
        exec "$DA_CODE_BIN" "$TASK_ID"
        ;;
    *)
        echo ""
        echo "✅ Spec saved: .tasks/${TASK_ID}/TASK.md"
        echo "ℹ️  When ready to implement:"
        echo "   make da-spec-approve TASK=${TASK_ID}"
        ;;
esac
