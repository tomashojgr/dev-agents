#!/usr/bin/env bash
set -euo pipefail

# ── Resolve task reference to full task ID ────────────────────────────────────

resolve_task() {
    local arg="$1" tasks_dir=".tasks" match matches count padded
    [ -d "${tasks_dir}/${arg}" ] && { echo "$arg"; return 0; }
    if [[ "$arg" =~ ^[0-9]+$ ]]; then
        padded=$(printf '%03d' "$arg")
        match=$(find "$tasks_dir" -maxdepth 1 -type d -name "task-${padded}-*" 2>/dev/null | head -1)
        [ -n "$match" ] && { basename "$match"; return 0; }
    fi
    matches=$(find "$tasks_dir" -maxdepth 1 -type d -name "*${arg}*" 2>/dev/null | sort)
    count=$(echo "$matches" | grep -c . 2>/dev/null || true)
    if [ "$count" -eq 1 ]; then basename "$matches"; return 0
    elif [ "$count" -gt 1 ]; then
        echo "❌ Multiple tasks match '${arg}':" >&2
        echo "$matches" | while IFS= read -r m; do echo "  $(basename "$m")"; done >&2
        return 1
    fi
    echo "❌ No task found matching '${arg}'" >&2; return 1
}

# ── Main ──────────────────────────────────────────────────────────────────────

TASK_ARG="${1:-}"
if [ -z "$TASK_ARG" ]; then
    echo "Usage: da-review <task>"
    echo "Example: da-review 1"
    echo "         da-review dkim"
    echo "         da-review task-001-add-dkim-validation"
    exit 1
fi

TASK_ID=$(resolve_task "$TASK_ARG") || exit 1

TASK_DIR=".tasks/${TASK_ID}"
TASK_FILE="${TASK_DIR}/TASK.md"
TASK_JSON="${TASK_DIR}/task.json"

if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

BRANCH="$TASK_ID"

# ── Switch to task branch ──────────────────────────────────────────────────────

if ! git show-ref --verify --quiet "refs/heads/${BRANCH}"; then
    echo "❌ Branch '${BRANCH}' not found. Was da-code run first?"
    exit 1
fi

git checkout "$BRANCH"

# ── Fetch PR comments ──────────────────────────────────────────────────────────

echo "▶ Fetching PR comments..."

COMMENTS=$(gh pr view --head "$BRANCH" --json comments,reviews --jq '
  ([.comments[] | "**Comment by @\(.author.login):**\n\(.body)"],
   [.reviews[] | select(.body != "") | "**Review (\(.state)) by @\(.author.login):**\n\(.body)"])
  | .[] | .[]
' 2>/dev/null || true)

if [ -z "$COMMENTS" ]; then
    echo "ℹ️  No comments found on the PR."
    exit 0
fi

echo "Found comments:"
echo "$COMMENTS" | head -20
echo ""

# ── Build prompt ───────────────────────────────────────────────────────────────

TASK_CONTENTS=$(cat "$TASK_FILE")
GOAL=$(awk '/^## Goal/{found=1; next} found && /^## /{exit} found && NF{print; exit}' "$TASK_FILE")

CLAUDE_MD_CONTEXT=""
if [ -f "CLAUDE.md" ]; then
    CLAUDE_MD_CONTEXT=$(cat "CLAUDE.md")
fi

PROMPT="You are an expert developer addressing code review feedback.

${CLAUDE_MD_CONTEXT}

Work fully autonomously — do not ask for confirmation, address all feedback using your best judgment.

Original task:
${TASK_CONTENTS}

PR review feedback to address:
${COMMENTS}

When done:
1. Run tests if a test suite exists and fix any failures
2. Stage all changed files with git add
3. Commit using conventional commit messages
4. Do NOT push — the calling script handles that"

# ── Mark as review-in-progress ────────────────────────────────────────────────

TMP=$(mktemp)
sed 's/"status"[[:space:]]*:[[:space:]]*"[^"]*"/"status": "review-in-progress"/' "$TASK_JSON" > "$TMP"
mv "$TMP" "$TASK_JSON"

# ── Launch AI agent ────────────────────────────────────────────────────────────

echo "🔁 Addressing review feedback for: ${TASK_ID}"
echo "   Goal: ${GOAL}"
echo ""

read -ra AI_AUTO <<< "${DA_AI_AUTO:-claude --dangerously-skip-permissions}"
"${AI_AUTO[@]}" "$PROMPT"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ AI agent exited with code $EXIT_CODE"
    exit $EXIT_CODE
fi

# ── Push updated branch ────────────────────────────────────────────────────────

echo ""
echo "▶ Pushing changes..."
git push

# ── Restore status to waiting-for-pr-review ───────────────────────────────────

TMP=$(mktemp)
sed 's/"status"[[:space:]]*:[[:space:]]*"[^"]*"/"status": "waiting-for-pr-review"/' "$TASK_JSON" > "$TMP"
mv "$TMP" "$TASK_JSON"

git add "$TASK_JSON"
git commit -m "chore: mark ${TASK_ID} as waiting-for-pr-review" 2>/dev/null || true
git push 2>/dev/null || true

echo ""
echo "✅ Changes pushed. PR updated — review again when ready."
echo "   make da-review TASK=${TASK_ID}"
