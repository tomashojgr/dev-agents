#!/usr/bin/env bash
set -euo pipefail

TASK_ID="${1:-}"
if [ -z "$TASK_ID" ]; then
    echo "Usage: da-commit <task-id>"
    echo "Example: da-commit task-001-dkim-validation"
    exit 1
fi

TASK_FILE=".tasks/${TASK_ID}/TASK.md"
if [ ! -f "$TASK_FILE" ]; then
    echo "❌ Task not found: ${TASK_FILE}"
    exit 1
fi

GOAL=$(awk '/^## Goal/{found=1; next} found && /^## /{exit} found && NF{print; exit}' "$TASK_FILE")
SCOPE=$(awk '/^## Scope/{found=1; next} found && /^## /{exit} found && /^- /{sub(/^- `?/, ""); sub(/`?$/, ""); print}' "$TASK_FILE")

if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not a git repository"
    exit 1
fi

DIFF=$(git diff --staged)
if [ -z "$DIFF" ]; then
    echo "❌ No staged changes. Use 'git add' first."
    exit 1
fi

CHANGED_FILES=$(git diff --staged --name-only)

echo "📋 Staged files:"
echo "$CHANGED_FILES"
echo ""

# Validate scope
if [ -n "$SCOPE" ]; then
    OUT_OF_SCOPE=""
    while IFS= read -r FILE; do
        IN_SCOPE=0
        while IFS= read -r ALLOWED; do
            [ -z "$ALLOWED" ] && continue
            if [[ "$FILE" == "$ALLOWED"* ]]; then
                IN_SCOPE=1
                break
            fi
        done <<< "$SCOPE"
        if [ $IN_SCOPE -eq 0 ]; then
            OUT_OF_SCOPE="${OUT_OF_SCOPE}   ${FILE}\n"
        fi
    done <<< "$CHANGED_FILES"

    if [ -n "$OUT_OF_SCOPE" ]; then
        echo "⚠️  Files outside task scope:"
        printf '%b' "$OUT_OF_SCOPE"
        printf '\nProceed anyway? [y/N] '
        read -r ANSWER
        ANSWER=$(printf '%s' "$ANSWER" | tr '[:upper:]' '[:lower:]')
        if [ "$ANSWER" != "y" ]; then
            echo "❌ Aborted"
            exit 1
        fi
    fi
fi

PROMPT="Generate git commit message(s) following Conventional Commits standard.

Task: ${GOAL}

Format: <type>(<scope>): <description>
Types: feat, fix, chore, docs, refactor, test, style, perf, ci
- scope optional but recommended
- imperative mood, lowercase, no period, max 72 chars

Rules:
- If diff contains multiple logical changes, output MULTIPLE lines
- Each message prefixed with \"COMMIT: \"
- Output ONLY the COMMIT: lines, nothing else

Changed files:
${CHANGED_FILES}

Diff:
${DIFF}"

read -ra AI_CMD <<< "${DA_AI_PRINT:-claude --print}"
RESPONSE=$("${AI_CMD[@]}" "$PROMPT" 2>/dev/null)

if [ -z "$RESPONSE" ]; then
    echo "❌ No response from AI CLI"
    exit 1
fi

# Parse commits
COMMITS=()
while IFS= read -r LINE; do
    if [[ "$LINE" == "COMMIT: "* ]]; then
        COMMITS+=("${LINE#COMMIT: }")
    fi
done <<< "$RESPONSE"

if [ ${#COMMITS[@]} -eq 0 ]; then
    echo "❌ No commit messages generated"
    echo "$RESPONSE"
    exit 1
fi

# Validate format
PATTERN='^(feat|fix|chore|docs|refactor|test|style|perf|ci)(\(.+\))?: .{3,}'
for MSG in "${COMMITS[@]}"; do
    if ! [[ "$MSG" =~ $PATTERN ]]; then
        echo "❌ Invalid format: $MSG"
        exit 1
    fi
done

echo "💬 Generated ${#COMMITS[@]} commit(s):"
for i in "${!COMMITS[@]}"; do
    echo "  $((i+1)). ${COMMITS[$i]}"
done

printf '\nProceed? [Y/n] '
read -r ANSWER
ANSWER=$(printf '%s' "$ANSWER" | tr '[:upper:]' '[:lower:]')

if [ "$ANSWER" = "n" ]; then
    echo "❌ Aborted"
    exit 1
fi

git commit -m "${COMMITS[0]}"

for i in "${!COMMITS[@]}"; do
    [ $i -eq 0 ] && continue
    echo ""
    echo "📝 Next commit (stage relevant files, then run):"
    printf '   git commit -m %q\n' "${COMMITS[$i]}"
done

echo ""
echo "✅ Done"
