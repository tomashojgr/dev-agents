#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --git-dir >/dev/null 2>&1; then
    echo "❌ Not a git repository"
    exit 1
fi

DIRTY=$(git status --porcelain)
if [ -n "$DIRTY" ]; then
    echo "❌ Working tree has uncommitted changes. Commit everything before releasing."
    git status --short
    exit 1
fi

# ── Determine current version ──────────────────────────────────────────────────

LATEST_TAG=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -1 || true)
CURRENT_VERSION="${LATEST_TAG#v}"
CURRENT_VERSION="${CURRENT_VERSION:-0.0.0}"

echo "Current version: v${CURRENT_VERSION}"

# ── Get commits since last tag ─────────────────────────────────────────────────

LOG_RANGE="${LATEST_TAG:+${LATEST_TAG}..HEAD}"
LOG=$(git log ${LOG_RANGE:-HEAD} --oneline 2>/dev/null || true)

if [ -z "$LOG" ]; then
    echo "❌ No commits since last release (v${CURRENT_VERSION})"
    exit 1
fi

echo ""
echo "Commits since v${CURRENT_VERSION}:"
while IFS= read -r LINE; do
    echo "  $LINE"
done <<< "$LOG"

# ── Determine bump type via AI ─────────────────────────────────────────────────

echo ""
echo "🤖 Analyzing commits for version bump..."

PROMPT="Analyze these git commits and determine the appropriate semantic version bump (major/minor/patch) following semver.org rules:
- major: breaking changes (BREAKING CHANGE in footer, or ! after type)
- minor: new features (feat:)
- patch: bug fixes, chores, docs (fix:, chore:, docs:, etc.)

Commits:
${LOG}

Respond with EXACTLY one line in this format:
BUMP: <major|minor|patch>
REASON: <one sentence explanation>
CHANGELOG:
- <bullet point per logical change, max 10>"

read -ra AI_CMD <<< "${DA_AI_PRINT:-claude --print}"
RESPONSE=$("${AI_CMD[@]}" "$PROMPT" 2>/dev/null)

if [ -z "$RESPONSE" ]; then
    echo "❌ No response from AI CLI"
    exit 1
fi

# ── Parse AI response ──────────────────────────────────────────────────────────

BUMP="patch"
REASON=""
CHANGELOG=()

while IFS= read -r LINE; do
    if [[ "$LINE" == "BUMP: "* ]]; then
        B="${LINE#BUMP: }"
        B=$(printf '%s' "$B" | tr '[:upper:]' '[:lower:]')
        [[ "$B" =~ ^(major|minor|patch)$ ]] && BUMP="$B"
    elif [[ "$LINE" == "REASON: "* ]]; then
        REASON="${LINE#REASON: }"
    elif [[ "$LINE" == "- "* ]]; then
        CHANGELOG+=("$LINE")
    fi
done <<< "$RESPONSE"

# ── Calculate next version ─────────────────────────────────────────────────────

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"
case "$BUMP" in
    major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
    minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
    *)     PATCH=$((PATCH + 1)) ;;
esac
NEXT_VERSION="v${MAJOR}.${MINOR}.${PATCH}"

# ── Confirm ────────────────────────────────────────────────────────────────────

echo ""
echo "────────────────────────────────────────────────────────────"
echo "Bump type:    ${BUMP}"
echo "Reason:       ${REASON}"
echo "New version:  ${NEXT_VERSION}"

if [ ${#CHANGELOG[@]} -gt 0 ]; then
    echo ""
    echo "Changelog:"
    for ENTRY in "${CHANGELOG[@]}"; do
        echo "  $ENTRY"
    done
fi

echo ""
echo "────────────────────────────────────────────────────────────"
printf 'Create release %s? [Y/n] ' "$NEXT_VERSION"
read -r ANSWER
ANSWER=$(printf '%s' "$ANSWER" | tr '[:upper:]' '[:lower:]')

if [ "$ANSWER" = "n" ]; then
    echo "❌ Release cancelled"
    exit 1
fi

# ── Tag release ────────────────────────────────────────────────────────────────

CHANGELOG_TEXT=$(printf '%s\n' "${CHANGELOG[@]}" 2>/dev/null || true)
TAG_MESSAGE="Release ${NEXT_VERSION}

${CHANGELOG_TEXT}"

git tag -a "$NEXT_VERSION" -m "$TAG_MESSAGE"

echo ""
echo "✅ Tagged release ${NEXT_VERSION}"
echo ""
echo "To push the release:"
echo "  git push origin ${NEXT_VERSION}"
