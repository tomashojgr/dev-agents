#!/usr/bin/env bash
set -euo pipefail

CWD="$(pwd)"
SAVE_PROMPT_FILE=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --save-prompt)
            SAVE_PROMPT_FILE="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

# ── Resolve tools ──────────────────────────────────────────────────────────────

declare -a TOOL_NAMES=()
declare -a TOOL_CMDS=()

if [ -f "$CWD/vendor/bin/phpstan" ]; then
    TOOL_NAMES+=("PHPStan"); TOOL_CMDS+=("vendor/bin/phpstan analyse --no-progress")
elif command -v phpstan >/dev/null 2>&1; then
    TOOL_NAMES+=("PHPStan"); TOOL_CMDS+=("phpstan analyse --no-progress")
fi

if [ -f "$CWD/vendor/bin/phpcs" ]; then
    TOOL_NAMES+=("PHP_CodeSniffer"); TOOL_CMDS+=("vendor/bin/phpcs")
elif command -v phpcs >/dev/null 2>&1; then
    TOOL_NAMES+=("PHP_CodeSniffer"); TOOL_CMDS+=("phpcs")
fi

if [ -f "$CWD/vendor/bin/php-cs-fixer" ]; then
    TOOL_NAMES+=("PHP CS Fixer"); TOOL_CMDS+=("vendor/bin/php-cs-fixer fix --dry-run --diff")
elif command -v php-cs-fixer >/dev/null 2>&1; then
    TOOL_NAMES+=("PHP CS Fixer"); TOOL_CMDS+=("php-cs-fixer fix --dry-run --diff")
fi

if [ -f "$CWD/vendor/bin/psalm" ]; then
    TOOL_NAMES+=("Psalm"); TOOL_CMDS+=("vendor/bin/psalm")
elif command -v psalm >/dev/null 2>&1; then
    TOOL_NAMES+=("Psalm"); TOOL_CMDS+=("psalm")
fi

# ── Fallback ───────────────────────────────────────────────────────────────────

if [ ${#TOOL_NAMES[@]} -eq 0 ]; then
    echo "ℹ️  No linters found in vendor/bin or PATH. Install phpstan or phpcs to enable linting."
    exit 0
fi

# ── Run each linter ────────────────────────────────────────────────────────────

declare -a FAILED_NAMES=()
declare -a FAILED_OUTPUTS=()

for i in "${!TOOL_NAMES[@]}"; do
    NAME="${TOOL_NAMES[$i]}"
    CMD="${TOOL_CMDS[$i]}"
    echo "▶ Running ${NAME}..."

    TOOL_FAILED=0
    OUTPUT=$(cd "$CWD" && eval "$CMD" 2>&1) || TOOL_FAILED=$?

    if [ "$TOOL_FAILED" -ne 0 ]; then
        echo "❌ ${NAME} failed"
        echo ""
        echo "$OUTPUT"
        echo ""
        FAILED_NAMES+=("$NAME")
        FAILED_OUTPUTS+=("$OUTPUT")
    else
        echo "✅ ${NAME} passed"
    fi
done

if [ ${#FAILED_NAMES[@]} -eq 0 ]; then
    echo ""
    echo "✅ All linters passed"
    exit 0
fi

# ── Save-prompt mode ───────────────────────────────────────────────────────────

if [ -n "$SAVE_PROMPT_FILE" ]; then
    # Run phpcbf first if available
    PHPCBF_CMD=""
    if [ -f "$CWD/vendor/bin/phpcbf" ]; then
        PHPCBF_CMD="vendor/bin/phpcbf"
    elif command -v phpcbf >/dev/null 2>&1; then
        PHPCBF_CMD="phpcbf"
    fi

    if [ -n "$PHPCBF_CMD" ]; then
        echo ""
        echo "▶ Running phpcbf (auto-fix style issues)..."
        cd "$CWD" && eval "$PHPCBF_CMD" 2>&1 || true

        echo ""
        echo "▶ Re-running linters after phpcbf..."
        FAILED_NAMES=()
        FAILED_OUTPUTS=()

        for i in "${!TOOL_NAMES[@]}"; do
            NAME="${TOOL_NAMES[$i]}"
            CMD="${TOOL_CMDS[$i]}"
            TOOL_FAILED=0
            OUTPUT=$(cd "$CWD" && eval "$CMD" 2>&1) || TOOL_FAILED=$?
            if [ "$TOOL_FAILED" -ne 0 ]; then
                echo "❌ ${NAME} still failing"
                FAILED_NAMES+=("$NAME")
                FAILED_OUTPUTS+=("$OUTPUT")
            else
                echo "✅ ${NAME} passed"
            fi
        done

        CHANGED=$(git diff --name-only 2>/dev/null || true)
        if [ -n "$CHANGED" ]; then
            git add -A
            git commit -m "style: auto-fix via phpcbf" && echo "✅ phpcbf changes committed" || true
        fi

        if [ ${#FAILED_NAMES[@]} -eq 0 ]; then
            echo ""
            echo "✅ All linters passed after phpcbf"
            exit 0
        fi
    fi

    ISSUE_TEXT=""
    for i in "${!FAILED_NAMES[@]}"; do
        ISSUE_TEXT="${ISSUE_TEXT}=== ${FAILED_NAMES[$i]} ===
${FAILED_OUTPUTS[$i]}

"
    done

    PROMPT="You are an expert PHP developer. The following linters reported errors in this project.

Fix all reported issues. Stay within the affected files — do not refactor unrelated code.

When done:
1. Run the linters again to verify all issues are resolved
2. Report a summary of what was changed

LINT OUTPUT:
${ISSUE_TEXT}"

    printf '%s' "$PROMPT" > "$SAVE_PROMPT_FILE"
    echo ""
    echo "ℹ️  Prompt saved to ${SAVE_PROMPT_FILE}"
fi

echo ""
echo "❌ Lint failed"
exit 1
